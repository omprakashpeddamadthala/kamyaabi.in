# =============================================================================
# Kamyaabi Production Environment Variables
# Copy this file to .env and update values before deployment
# =============================================================================
#
# --- Switching domains ---
# The entire stack is driven by the single DOMAIN variable below. Changing it
# cascades into CORS, email defaults, Nginx server_name, SSL certificates, the
# frontend contact email, and the Swagger contact URL (via the VITE_* build
# args and backend app.support.* properties).
#
# To switch the domain (e.g. back to kamyaabi.in):
#   1. Set DOMAIN=kamyaabi.in below.
#   2. (Optional) Override CORS_ALLOWED_ORIGINS / EMAIL_FROM / ADMIN_EMAIL /
#      CERTBOT_EMAIL / VITE_SUPPORT_EMAIL / VITE_BRAND_DOMAIN only if you need
#      them to differ from the default (which is derived from DOMAIN).
#   3. Re-run `sudo ./setup-vm-ssl.sh` on the VM to re-issue SSL for the new
#      domain and update Nginx, then `./deploy.sh` to re-deploy containers
#      (rebuild the frontend image if you changed VITE_* vars).
# =============================================================================

# --- Domain Configuration ---
DOMAIN=kamyaabi.shop
CERTBOT_EMAIL=admin@kamyaabi.shop
# Set CERTBOT_STAGING=1 to use the Let's Encrypt staging CA (avoids rate limits).
CERTBOT_STAGING=0

# --- External Database (PostgreSQL) ---
DATABASE_URL=jdbc:postgresql://your-db-host:5432/kamyaabi
DATABASE_USERNAME=your-db-username
DATABASE_PASSWORD=your-secure-db-password

# --- Backend (Spring Boot) ---
JWT_SECRET=your-production-jwt-secret-key-must-be-at-least-256-bits-long-for-hs256
CORS_ALLOWED_ORIGINS=https://kamyaabi.shop

# --- Google OAuth ---
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# --- Razorpay Payment ---
RAZORPAY_KEY_ID=your-razorpay-key-id
RAZORPAY_KEY_SECRET=your-razorpay-key-secret

# --- Email Configuration ---
EMAIL_ENABLED=true
EMAIL_FROM=noreply@kamyaabi.shop
EMAIL_FROM_NAME=Kamyaabi
ADMIN_EMAIL=admin@kamyaabi.shop
SENDGRID_API_KEY=your-sendgrid-api-key
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=

# --- Frontend (Vite build args) ---
VITE_API_BASE_URL=
VITE_GOOGLE_CLIENT_ID=your-google-client-id
VITE_BRAND_DOMAIN=kamyaabi.shop
VITE_SUPPORT_EMAIL=support@kamyaabi.shop

# --- Backend Support / Swagger contact (surfaced in OpenAPI metadata) ---
APP_SUPPORT_EMAIL=support@kamyaabi.shop
APP_SUPPORT_URL=https://kamyaabi.shop

# --- Docker Image Tags (production only, used by docker-compose.prod.yml) ---
BACKEND_IMAGE_TAG=latest
FRONTEND_IMAGE_TAG=latest
