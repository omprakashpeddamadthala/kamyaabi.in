FROM node:20-alpine AS build
WORKDIR /app
COPY package.json package-lock.json ./
RUN npm ci
COPY . .

ARG VITE_API_BASE_URL=
ARG VITE_GOOGLE_CLIENT_ID=
ARG VITE_BRAND_DOMAIN=kamyaabi.in
ARG VITE_SUPPORT_EMAIL=sm.enterprises0121@gmail.com
ARG VITE_SUPPORT_PHONE=9848999072
ARG VITE_GA_ID=G-M887QJRB53
ARG VITE_FACEBOOK_URL=
ARG VITE_INSTAGRAM_URL=
ENV VITE_API_BASE_URL=$VITE_API_BASE_URL
ENV VITE_GOOGLE_CLIENT_ID=$VITE_GOOGLE_CLIENT_ID
ENV VITE_BRAND_DOMAIN=$VITE_BRAND_DOMAIN
ENV VITE_SUPPORT_EMAIL=$VITE_SUPPORT_EMAIL
ENV VITE_SUPPORT_PHONE=$VITE_SUPPORT_PHONE
ENV VITE_GA_ID=$VITE_GA_ID
ENV VITE_FACEBOOK_URL=$VITE_FACEBOOK_URL
ENV VITE_INSTAGRAM_URL=$VITE_INSTAGRAM_URL

RUN npm run build

FROM node:20-alpine
WORKDIR /app
ENV NODE_ENV=production
ENV PORT=80
ENV BACKEND_INTERNAL_URL=http://backend:8080
ENV PUBLIC_SITE_URL=https://kamyaabi.in
COPY --from=build /app/dist ./dist
COPY server ./server
EXPOSE 80
CMD ["node", "server/index.mjs"]
