<?xml version="1.0" encoding="UTF-8"?>
<!--
    Kamyaabi backend logging configuration.

    - Console appender: always on, used locally and in containers.
    - Rolling file appender: ${LOG_HOME}/application.log, daily rotation,
      10-day retention (Logback auto-deletes anything older — no cron job needed).
    - Error file appender: ${LOG_HOME}/error.log, same rotation/retention, ERROR-level only.
    - Profile-based root levels: DEBUG for dev, INFO for prod/docker.

    LOG_HOME is overridable via the LOG_HOME environment variable (default: ./logs).
    For Docker deployments, /app/logs inside the container is bind-mounted to ./logs
    on the host (see docker-compose.yml / docker-compose.prod.yml) so operators can
    `tail -f logs/application.log` directly on the host.

    Pattern includes the MDC `correlationId` populated by CorrelationIdFilter so every
    log line can be correlated back to its originating HTTP request. Field is rendered
    as "-" when no request context is present (startup, scheduled jobs, etc.).
-->
<configuration scan="true" scanPeriod="30 seconds">

    <springProperty scope="context" name="APP_NAME" source="spring.application.name" defaultValue="kamyaabi-backend"/>

    <!--
         Resolve LOG_HOME from the environment / system property; fall back to the
         relative `logs` directory (which becomes /app/logs inside Docker because
         the Dockerfile sets WORKDIR /app, and is bind-mounted to ./logs on the host).
    -->
    <property name="LOG_HOME" value="${LOG_HOME:-logs}"/>
    <property name="LOG_PATTERN"
              value="%d{yyyy-MM-dd HH:mm:ss.SSS} [%-5level] [correlationId=%X{correlationId:--}] [thread=%thread] %logger{40} - %msg%n"/>

    <!-- ======================== CONSOLE ======================== -->
    <appender name="CONSOLE" class="ch.qos.logback.core.ConsoleAppender">
        <encoder>
            <pattern>${LOG_PATTERN}</pattern>
        </encoder>
    </appender>

    <!-- ===================== ROLLING FILE ====================== -->
    <appender name="FILE" class="ch.qos.logback.core.rolling.RollingFileAppender">
        <file>${LOG_HOME}/application.log</file>
        <!--
             10-day retention: archived files older than 10 days are auto-deleted by
             Logback on rollover (and at startup, via cleanHistoryOnStart). totalSizeCap
             is a belt-and-braces guard against unexpected log volume spikes.
        -->
        <rollingPolicy class="ch.qos.logback.core.rolling.TimeBasedRollingPolicy">
            <fileNamePattern>${LOG_HOME}/application-%d{yyyy-MM-dd}.log</fileNamePattern>
            <maxHistory>10</maxHistory>
            <cleanHistoryOnStart>true</cleanHistoryOnStart>
            <totalSizeCap>1GB</totalSizeCap>
        </rollingPolicy>
        <encoder>
            <pattern>${LOG_PATTERN}</pattern>
        </encoder>
    </appender>

    <!-- ====================== ERROR FILE ======================= -->
    <appender name="ERROR_FILE" class="ch.qos.logback.core.rolling.RollingFileAppender">
        <file>${LOG_HOME}/error.log</file>
        <filter class="ch.qos.logback.classic.filter.ThresholdFilter">
            <level>ERROR</level>
        </filter>
        <!-- 10-day retention; older archives auto-deleted by Logback on rollover. -->
        <rollingPolicy class="ch.qos.logback.core.rolling.TimeBasedRollingPolicy">
            <fileNamePattern>${LOG_HOME}/error-%d{yyyy-MM-dd}.log</fileNamePattern>
            <maxHistory>10</maxHistory>
            <cleanHistoryOnStart>true</cleanHistoryOnStart>
            <totalSizeCap>1GB</totalSizeCap>
        </rollingPolicy>
        <encoder>
            <pattern>${LOG_PATTERN}</pattern>
        </encoder>
    </appender>

    <!-- ==================== PROFILE-AWARE ROOTS ==================== -->
    <springProfile name="dev">
        <root level="INFO">
            <appender-ref ref="CONSOLE"/>
            <appender-ref ref="FILE"/>
            <appender-ref ref="ERROR_FILE"/>
        </root>
        <logger name="com.kamyaabi" level="DEBUG"/>
    </springProfile>

    <springProfile name="prod">
        <root level="INFO">
            <appender-ref ref="CONSOLE"/>
            <appender-ref ref="FILE"/>
            <appender-ref ref="ERROR_FILE"/>
        </root>
        <logger name="com.kamyaabi" level="INFO"/>
    </springProfile>

    <springProfile name="docker">
        <root level="INFO">
            <appender-ref ref="CONSOLE"/>
            <appender-ref ref="FILE"/>
            <appender-ref ref="ERROR_FILE"/>
        </root>
        <logger name="com.kamyaabi" level="INFO"/>
    </springProfile>

    <!-- Fallback for profile-less runs (e.g. tests). -->
    <springProfile name="!dev &amp; !prod &amp; !docker">
        <root level="INFO">
            <appender-ref ref="CONSOLE"/>
        </root>
    </springProfile>

</configuration>
